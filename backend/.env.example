# Copy this file to .env and replace the value with your own Supabase PostgreSQL connection string.
# URL-encode the database password if it contains special characters such as @ : / ? # % [ ]
DATABASE_URL=postgresql://postgres.your-project-ref:YOUR_URL_ENCODED_PASSWORD@aws-1-ap-southeast-2.pooler.supabase.com:5432/postgres

# Supabase project settings used by the FastAPI backend to call Supabase Auth endpoints.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-or-publishable-key